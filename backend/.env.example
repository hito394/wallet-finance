DATABASE_URL=sqlite+aiosqlite:///./finance.db
DEFAULT_USER_ID=1
UPLOAD_DIR=./uploads
TESSERACT_LANG=jpn+eng
MAX_UPLOAD_SIZE_MB=50
RECEIPT_MATCH_AMOUNT_TOLERANCE=0.01
RECEIPT_MATCH_DATE_TOLERANCE_DAYS=3

# 例: CORS_ALLOW_ORIGINS=https://finance.example.com,https://www.finance.example.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 例: TRUSTED_HOSTS=finance-api.example.com
TRUSTED_HOSTS=localhost,127.0.0.1
