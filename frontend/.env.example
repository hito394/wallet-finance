# クライアント側から直接APIを叩く場合（通常は未設定でOK）
# 例: https://finance-api.example.com
NEXT_PUBLIC_API_BASE_URL=

# Next.jsサーバーコンポーネントが参照するバックエンドURL
# 開発環境ではこのままでOK
NEXT_SERVER_API_ORIGIN=http://127.0.0.1:8000

# next.config.js の /api リライト先
# 本番では https://finance-api.example.com などに変更
BACKEND_API_ORIGIN=http://127.0.0.1:8000
